{
  "dashboard": {
    "id": null,
    "title": "UDS Agent Performance",
    "tags": ["uds-agent", "performance", "latency"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Request Throughput",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"uds-agent\"}[1m])",
            "legendFormat": "Requests/sec (1m avg)"
          },
          {
            "expr": "rate(http_requests_total{job=\"uds-agent\"}[5m])",
            "legendFormat": "Requests/sec (5m avg)"
          },
          {
            "expr": "rate(http_requests_total{job=\"uds-agent\"}[15m])",
            "legendFormat": "Requests/sec (15m avg)"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Response Time Distribution",
        "type": "heatmap",
        "targets": [
          {
            "expr": "rate(http_request_duration_seconds_bucket{job=\"uds-agent\"}[5m])",
            "legendFormat": "{{ le }}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Response Time Percentiles Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"uds-agent\"}[5m]))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.90, rate(http_request_duration_seconds_bucket{job=\"uds-agent\"}[5m]))",
            "legendFormat": "P90"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"uds-agent\"}[5m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"uds-agent\"}[5m]))",
            "legendFormat": "P99"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Apdex Score",
        "type": "singlestat",
        "targets": [
          {
            "expr": "(rate(http_request_duration_seconds_bucket{job=\"uds-agent\", le=\"1.0\"}[5m]) + rate(http_request_duration_seconds_bucket{job=\"uds-agent\", le=\"4.0\"}[5m])) / (2 * rate(http_request_duration_seconds_bucket{job=\"uds-agent\"}[5m]))",
            "legendFormat": "Apdex Score"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Request Duration by Endpoint",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"uds-agent\"}[5m])) by (path)",
            "legendFormat": "{{ path }} P95"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Database Query Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(clickhouse_queries_total[5m])",
            "legendFormat": "Queries/sec"
          },
          {
            "expr": "histogram_quantile(0.95, rate(clickhouse_query_duration_seconds_bucket[5m]))",
            "legendFormat": "P95 Query Time"
          },
          {
            "expr": "histogram_quantile(0.99, rate(clickhouse_query_duration_seconds_bucket[5m]))",
            "legendFormat": "P99 Query Time"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        }
      },
      {
        "id": 7,
        "title": "Cache Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(cache_operations_total{operation=\"get\"}[5m])",
            "legendFormat": "Cache Gets/sec"
          },
          {
            "expr": "rate(cache_operations_total{operation=\"set\"}[5m])",
            "legendFormat": "Cache Sets/sec"
          },
          {
            "expr": "(rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m]))) * 100",
            "legendFormat": "Hit Rate %"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        }
      },
      {
        "id": 8,
        "title": "LLM Service Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(llm_request_duration_seconds_bucket[5m]))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(llm_request_duration_seconds_bucket[5m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(llm_request_duration_seconds_bucket[5m]))",
            "legendFormat": "P99"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        }
      },
      {
        "id": 9,
        "title": "Tool Execution Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(tool_execution_duration_seconds_bucket[5m])) by (tool_name)",
            "legendFormat": "{{ tool_name }} P95"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 24
        }
      },
      {
        "id": 10,
        "title": "Concurrent Requests",
        "type": "graph",
        "targets": [
          {
            "expr": "http_requests_in_flight{job=\"uds-agent\"}",
            "legendFormat": "In-flight Requests"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 32
        }
      },
      {
        "id": 11,
        "title": "Queue Depth",
        "type": "graph",
        "targets": [
          {
            "expr": "http_requests_queued{job=\"uds-agent\"}",
            "legendFormat": "Queued Requests"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 32
        }
      }
    ],
    "time": {
      "from": "now-3h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 0,
    "links": []
  }
}