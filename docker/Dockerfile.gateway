# Multi-stage Dockerfile for Gateway API
# Target image size: <500MB

# Build stage
FROM python:3.11-slim as builder

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies for building
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --upgrade pip && \
    pip install -r requirements.txt

# Production stage
FROM python:3.11-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -r gateway && useradd -r -g gateway gateway

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/opt/venv/bin:$PATH" \
    PYTHONPATH="/app/src" \
    GATEWAY_HOST="0.0.0.0" \
    GATEWAY_PORT="8001"

# Copy virtual environment from builder
COPY --from=builder /opt/venv /opt/venv

# Create app directory and set permissions
RUN mkdir -p /app && chown -R gateway:gateway /app
WORKDIR /app

# Copy application code
COPY --chown=gateway:gateway src/ ./src/
COPY --chown=gateway:gateway scripts/ ./scripts/
COPY --chown=gateway:gateway docs/ ./docs/

# Switch to non-root user
USER gateway

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

# Expose port
EXPOSE 8001

# Start application
CMD ["python", "scripts/run_gateway.py"]

flowchart TD
    Q[User Query] --> L1{Level 1\nRetrieval or Action?}
    L1 -->|Retrieval| L2A{Level 2}
    L1 -->|Action| L2B{Level 2}
    L2A --> W1[General Knowledge\nRemote LLM]
    L2A --> W2[Amazon Docs\nChromaDB]
    L2A --> W3[IC Enterprise Docs\nChromaDB]
    L2B --> W4[SP-API Agent\nSeller Operations]
    L2B --> W5[UDS Agent\nBI Analytics → ClickHouse]