# Alibaba Container Registry
ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com/your-namespace
VERSION=latest

# ClickHouse Database Configuration
CLICKHOUSE_HOST=${CH_HOST}
CLICKHOUSE_PORT=${CH_PORT}
CLICKHOUSE_DATABASE=${CH_DATABASE}
CLICKHOUSE_USER=${CH_USER}
CLICKHOUSE_PASSWORD=${CH_PASSWORD}

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Gateway short-term memory (Redis-backed session history)
GATEWAY_REDIS_URL=redis://redis:6379/0
GATEWAY_SESSION_TTL=86400

# LLM Configuration
LLM_PROVIDER=ollama
LLM_BASE_URL=http://${CH_HOST}:11434
LLM_MODEL=qwen3:1.7b

# ChromaDB ECS (for transfer and production RAG)
CHROMA_ECS_HOST=chromadb
CHROMA_ECS_PORT=8000
CHROMA_ECS_SSL=false

# Route LLM - Ollama (clarification, rewrite, workflow classification)
GATEWAY_REWRITE_OLLAMA_URL=http://${CH_HOST}:11434/api/generate
GATEWAY_REWRITE_OLLAMA_MODEL=qwen3:1.7b
GATEWAY_ROUTE_LLM_OLLAMA_URL=http://${CH_HOST}:11434
GATEWAY_ROUTE_LLM_OLLAMA_MODEL=qwen3:1.7b

# Application Configuration
LOG_LEVEL=INFO
WORKERS=4
