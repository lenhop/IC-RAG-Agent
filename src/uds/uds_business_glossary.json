{
  "glossary": {
    "ASIN": {
      "full_name": "Amazon Standard Identification Number",
      "definition": "A unique 10-character alphanumeric identifier assigned by Amazon to products",
      "usage": "Used to identify products in the catalog",
      "related_tables": ["amz_product", "amz_order", "amz_fee"],
      "examples": ["B08N5WRWNW", "B07XJ8C8F5"]
    },
    "SKU": {
      "full_name": "Stock Keeping Unit",
      "definition": "Seller-defined identifier for products in their inventory",
      "usage": "Used to track inventory and orders",
      "related_tables": ["amz_order", "amz_listing_item", "amz_fba_inventory_all"],
      "examples": ["PROD-001", "SKU-12345"]
    },
    "FNSKU": {
      "full_name": "Fulfillment Network Stock Keeping Unit",
      "definition": "Amazon's unique identifier for products in FBA warehouses",
      "usage": "Used to track FBA inventory",
      "related_tables": ["amz_fba_inventory_all", "amz_daily_inventory_ledger"],
      "examples": ["X001234567"]
    },
    "FBA": {
      "full_name": "Fulfillment by Amazon",
      "definition": "Amazon's fulfillment service where Amazon stores, picks, packs, and ships products",
      "usage": "Inventory management and fulfillment",
      "related_tables": ["amz_fba_inventory_all", "amz_daily_inventory_ledger"],
      "examples": []
    },
    "GMV": {
      "full_name": "Gross Merchandise Value",
      "definition": "Total sales value before deducting fees and costs",
      "usage": "Measure of total sales volume",
      "related_tables": ["amz_order", "amz_transaction"],
      "calculation": "SUM(item_price) from amz_order"
    },
    "AOV": {
      "full_name": "Average Order Value",
      "definition": "Average amount spent per order",
      "usage": "Measure of customer spending behavior",
      "related_tables": ["amz_order"],
      "calculation": "AVG(item_price) from amz_order"
    },
    "Settlement": {
      "full_name": "Settlement Period",
      "definition": "Period for which Amazon calculates and transfers payments to sellers",
      "usage": "Financial reconciliation",
      "related_tables": ["amz_statement", "amz_transaction"],
      "examples": []
    },
    "Marketplace": {
      "full_name": "Amazon Marketplace",
      "definition": "Geographic region where products are sold (e.g., US, UK, DE)",
      "usage": "Multi-region sales analysis",
      "related_tables": ["amz_order", "amz_listing_item"],
      "examples": ["ATVPDKIKX0DER (US)", "A1F83G8C2ARO7P (UK)"]
    },
    "Inventory Turnover": {
      "full_name": "Inventory Turnover Rate",
      "definition": "How quickly inventory is sold and replaced",
      "usage": "Measure of inventory efficiency",
      "related_tables": ["amz_order", "amz_fba_inventory_all"],
      "calculation": "Units Sold / Average Inventory"
    },
    "Stockout": {
      "full_name": "Stock Outage",
      "definition": "When a product has zero inventory available",
      "usage": "Inventory management alert",
      "related_tables": ["amz_fba_inventory_all"],
      "examples": []
    },
    "Referral Fee": {
      "full_name": "Amazon Referral Fee",
      "definition": "Percentage-based fee charged by Amazon for each sale",
      "usage": "Cost calculation",
      "related_tables": ["amz_fee", "amz_transaction"],
      "calculation": "Typically 8-15% of sale price"
    },
    "FBA Fee": {
      "full_name": "Fulfillment by Amazon Fee",
      "definition": "Fee charged for FBA services (storage, picking, packing, shipping)",
      "usage": "Cost calculation",
      "related_tables": ["amz_fee"],
      "examples": []
    },
    "Search Term": {
      "full_name": "Customer Search Term",
      "definition": "Keywords customers use to find products on Amazon",
      "usage": "SEO and product discovery analysis",
      "related_tables": ["amz_monthly_search_term"],
      "examples": ["wireless headphones", "laptop stand"]
    },
    "Search Frequency Rank": {
      "full_name": "Search Frequency Ranking",
      "definition": "Ranking of search terms by how often they're searched",
      "usage": "Identify popular search terms",
      "related_tables": ["amz_monthly_search_term"],
      "examples": []
    },
    "Profit Margin": {
      "full_name": "Net Profit Margin",
      "definition": "Percentage of revenue remaining after all fees and costs",
      "usage": "Profitability analysis",
      "related_tables": ["amz_order", "amz_fee", "amz_transaction"],
      "calculation": "(Revenue - Fees) / Revenue * 100"
    },
    "Conversion Rate": {
      "full_name": "Sales Conversion Rate",
      "definition": "Percentage of product views that result in sales",
      "usage": "Product performance metric",
      "related_tables": ["amz_order"],
      "calculation": "Orders / Views * 100"
    },
    "Listing": {
      "full_name": "Product Listing",
      "definition": "Product page on Amazon with title, images, description, price",
      "usage": "Product catalog management",
      "related_tables": ["amz_listing_item", "amz_product"],
      "examples": []
    },
    "Channel": {
      "full_name": "Sales Channel",
      "definition": "Platform or marketplace where product is sold",
      "usage": "Multi-channel sales tracking",
      "related_tables": ["amz_listing_item"],
      "examples": ["Amazon.com", "Amazon.co.uk"]
    }
  },
  "metrics": {
    "Total Sales": {
      "definition": "Sum of all order amounts",
      "sql": "SELECT SUM(item_price) FROM ic_agent.amz_order",
      "unit": "USD"
    },
    "Order Count": {
      "definition": "Total number of orders",
      "sql": "SELECT COUNT(DISTINCT amazon_order_id) FROM ic_agent.amz_order",
      "unit": "orders"
    },
    "Average Order Value": {
      "definition": "Average amount per order",
      "sql": "SELECT AVG(item_price) FROM ic_agent.amz_order",
      "unit": "USD"
    },
    "Total Units Sold": {
      "definition": "Total quantity of items sold",
      "sql": "SELECT SUM(quantity) FROM ic_agent.amz_order",
      "unit": "units"
    },
    "Total Inventory": {
      "definition": "Total units in FBA warehouses",
      "sql": "SELECT SUM(afn_fulfillable_quantity) FROM ic_agent.amz_fba_inventory_all WHERE start_date = (SELECT MAX(start_date) FROM ic_agent.amz_fba_inventory_all)",
      "unit": "units"
    },
    "Total Fees": {
      "definition": "Sum of all Amazon fees",
      "sql": "SELECT SUM(fee_amount) FROM ic_agent.amz_fee",
      "unit": "USD"
    },
    "Net Revenue": {
      "definition": "Revenue after fees",
      "sql": "SELECT SUM(item_price) - (SELECT SUM(fee_amount) FROM ic_agent.amz_fee) FROM ic_agent.amz_order",
      "unit": "USD"
    }
  },
