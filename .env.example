# ============================================
# AI Model API Keys
# ============================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
QWEN_API_KEY=your_qwen_api_key_here
GLM_API_KEY=your_glm_api_key_here

# Optional: OpenAI API Key (for comparison)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API Key (for comparison)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Embedding Model Configuration
# ============================================
# DashScope/Qwen Embedding API Key (for document vectorization)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_DIMENSION=1536

# ============================================
# UDS Database Configuration
# ============================================
UDS_DB_HOST=localhost
UDS_DB_PORT=5432
UDS_DB_NAME=uds_database
UDS_DB_USER=your_db_user_here
UDS_DB_PASSWORD=your_db_password_here
UDS_DB_TYPE=postgresql  # postgresql or mysql

# ============================================
# Redis Configuration (for conversation memory)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_DECODE_RESPONSES=True

# ============================================
# Vector Database Configuration
# ============================================
# Chroma (for development)
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIRECTORY=data/vector_store/chroma
CHROMA_DOCUMENTS_PATH=data/chroma_db/documents
# Disable Chroma telemetry to avoid "Failed to send telemetry event" errors (optional; code also sets anonymized_telemetry=False)
ANONYMIZED_TELEMETRY=FALSE

# Milvus (for production) - uncomment if using Milvus
# VECTOR_DB_TYPE=milvus
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_COLLECTION_NAME=ecommerce_rag_agent

# ============================================
# Platform API Configuration
# ============================================
# Amazon SP-API (fast_api.py uses SP_API_* prefix)
# For local testing without credentials: SP_API_TEST_MODE=true
SP_API_TEST_MODE=false
SP_API_REFRESH_TOKEN=your_refresh_token_here
SP_API_CLIENT_ID=your_client_id_here
SP_API_CLIENT_SECRET=your_client_secret_here
SP_API_MARKETPLACE_ID=ATVPDKIKX0DER

# Legacy / alternate naming (if your env uses these)
AMAZON_SP_API_CLIENT_ID=your_amazon_client_id_here
AMAZON_SP_API_CLIENT_SECRET=your_amazon_client_secret_here
AMAZON_SP_API_REFRESH_TOKEN=your_amazon_refresh_token_here
AMAZON_SP_API_REGION=us-east-1

# eBay API
EBAY_API_APP_ID=your_ebay_app_id_here
EBAY_API_CERT_ID=your_ebay_cert_id_here
EBAY_API_DEV_ID=your_ebay_dev_id_here
EBAY_API_ENVIRONMENT=sandbox  # sandbox or production

# Target API
TARGET_API_KEY=your_target_api_key_here
TARGET_API_SECRET=your_target_api_secret_here

# Walmart API
WALMART_API_KEY=your_walmart_api_key_here
WALMART_API_SECRET=your_walmart_api_secret_here

# ============================================
# RAG Configuration
# ============================================
# Document Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIEVAL_DOCS=5
SIMILARITY_THRESHOLD=0.7

# ReRank Configuration (optional)
USE_RERANK=False
RERANK_MODEL=bge-reranker-base
RERANK_TOP_N=3

# RAG LLM provider: ollama (local) or deepseek, qwen, glm (remote)
# Remote providers use DEEPSEEK_API_KEY, QWEN_API_KEY, GLM_API_KEY
RAG_LLM_PROVIDER=ollama
RAG_LLM_MODEL=qwen3:1.7b

# Data leakage prevention: separate LLMs for documents vs general
# Documents: always local (ollama) - never send proprietary docs to remote
RAG_DOCUMENTS_LLM_PROVIDER=ollama
RAG_DOCUMENTS_LLM_MODEL=qwen3:1.7b
# General: can be remote (no document data)
RAG_GENERAL_LLM_PROVIDER=ollama
RAG_GENERAL_LLM_MODEL=qwen3:1.7b

# Line 3: LLM classify (default off) - when true, run LLM for intent classification
RAG_LLM_CLASSIFY_ENABLED=false

# Intent aggregation: when all four methods return No, use general/documents/hybrid
RAG_AGGREGATE_NO_MODE=general
# When >=1 Yes: documents or hybrid
RAG_AGGREGATE_YES_MODE=hybrid

# Hybrid mode merge strategy: concatenate (default), doc-priority, synthesize
# concatenate: always append general to doc; use when both answers add value
# doc-priority: only append general when doc cannot answer; use when doc is authoritative
# synthesize: third LLM call to combine both; use when coherent single answer needed
RAG_HYBRID_MERGE_STRATEGY=concatenate

# FAQ-derived keywords for intent classification (optional)
# When enabled, extracts keywords from FAQ questions and combines with env + title phrases
RAG_FAQ_KEYWORDS_ENABLED=false
RAG_FAQ_KEYWORDS_TOP_N=50

# Load to Chroma presets (load_to_chroma.py fqa/keywords)
# FAQ CSV path for intent classification
RAG_FAQ_CSV=data/intent_classification/fqa/amazon_fqa.csv
# Title phrases CSV for keywords
RAG_TITLE_PHRASES_CSV=data/intent_classification/keywords/phrases_from_titles.csv
# Chroma persist paths for fqa and keywords collections
CHROMA_FQA_PATH=data/chroma_db/fqa_question
CHROMA_KEYWORD_PATH=data/chroma_db/keyword

# ChromaDB ECS (for load_vector_registry, transfer_chroma_to_ecs, test_chroma_ecs_connection)
CHA_HOST=8.163.3.40
CHA_PORT=8000
# Fallback (optional)
CHROMA_ECS_HOST=localhost
CHROMA_ECS_PORT=8001
CHROMA_ECS_SSL=false

# ============================================
# FastAPI Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
API_WORKERS=4
API_TITLE=E-commerce RAG Agent API
API_VERSION=1.0.0

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ============================================
# Client Configuration
# ============================================
# Gateway API URL (unified gateway server; empty or mock mode if unavailable)
GATEWAY_API_URL=http://127.0.0.1:8001
# Enable mock mode: use local mock responses instead of calling gateway
GATEWAY_MOCK=false
# Client Gradio UI port (unified chat interface)
CLIENT_GRADIO_PORT=7862

# ============================================
# Gateway Configuration
# ============================================
# Gateway FastAPI server settings (gateway listens on GATEWAY_PORT; default 8000 in code)
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_LOG_LEVEL=info
GATEWAY_WORKERS=1
GATEWAY_RELOAD=false

# Gateway short-term memory (Redis-backed session history)
GATEWAY_REDIS_URL=redis://localhost:6379/0
GATEWAY_SESSION_TTL=86400
# Number of history turns to merge in rewriting (default 3)
GATEWAY_REWRITE_MEMORY_ROUNDS=3
# Intent classification on optimized retrieval query (default false).
# When true, runs after rewriting to extract sub-questions for multi-task plans.
# GATEWAY_REWRITE_PLANNER_ENABLED=true also enables this (backward compat).
GATEWAY_INTENT_CLASSIFICATION_ENABLED=false

# Gateway downstream backends (per GATEWAY_DEVELOPMENT_PLAN: RAG 8002, UDS 8001, SP-API 8003)
RAG_API_URL=http://127.0.0.1:8002
UDS_API_URL=http://127.0.0.1:8001
SP_API_URL=http://127.0.0.1:8003
# IC docs: when false (default), gateway returns a friendly message and does not call RAG (Chroma not populated yet)
IC_DOCS_ENABLED=false

# Clarification: required by default. Set GATEWAY_CLARIFICATION_ENABLED=false to disable.
GATEWAY_CLARIFICATION_ENABLED=true

# Route LLM - Ollama (clarification, rewrite, workflow classification)
# Use ECS Ollama when running gateway locally against ECS backends
GATEWAY_REWRITE_OLLAMA_URL=http://8.163.3.40:11434/api/generate
GATEWAY_REWRITE_OLLAMA_MODEL=qwen3:1.7b
GATEWAY_ROUTE_LLM_OLLAMA_URL=http://8.163.3.40:11434
GATEWAY_ROUTE_LLM_OLLAMA_MODEL=qwen3:1.7b

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ERROR_FILE=logs/error.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ============================================
# Development Settings
# ============================================
DEBUG=False
ENVIRONMENT=development

# Cache Configuration
CACHE_ENABLED=True
CACHE_TTL=3600  # seconds
CACHE_MAX_SIZE=1000

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds
